# ──────────────────────────────────────────────────────────────────────────
# Base de datos
# ──────────────────────────────────────────────────────────────────────────
# Desarrollo local (SQLite): el provider en prisma/schema.prisma debe ser "sqlite".
DATABASE_URL="file:./dev.db"
#
# Producción (PostgreSQL): cambiá el provider a "postgresql" en prisma/schema.prisma
# y usá una URL de conexión. Ejemplo (Neon / Supabase / Vercel Postgres):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ──────────────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ──────────────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Generá uno con: openssl rand -base64 32
AUTH_SECRET="reemplazá-esto-por-un-secreto-largo-y-aleatorio"
# En producción configurá la URL pública del sitio.
# AUTH_URL="https://tu-dominio.com"
# Confiar en el host detrás del proxy (necesario en algunos hostings).
AUTH_TRUST_HOST="true"

# ──────────────────────────────────────────────────────────────────────────
# Reglas de negocio
# ──────────────────────────────────────────────────────────────────────────
# Zona horaria de la consultoría (IANA). Las disponibilidades se interpretan en esta TZ.
NEXT_PUBLIC_TIMEZONE="America/Argentina/Buenos_Aires"
# Antelación mínima (en horas) con la que un paciente puede cancelar un turno.
CANCELLATION_MIN_HOURS="24"
# Antelación mínima (en horas) con la que un paciente puede reservar un turno.
BOOKING_MIN_LEAD_HOURS="2"
# Granularidad (en minutos) de los slots ofrecidos al reservar.
SLOT_INTERVAL_MINUTES="15"

# ──────────────────────────────────────────────────────────────────────────
# Datos del seed (credenciales de prueba)
# ──────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@kinesio.local"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_PATIENT_EMAIL="paciente@kinesio.local"
SEED_PATIENT_PASSWORD="Paciente123!"
