# ──────────────────────────────────────────────────────────────────────────
# Base de datos — PostgreSQL (Supabase)
# ──────────────────────────────────────────────────────────────────────────
# DATABASE_URL: pooler de TRANSACCIÓN (puerto 6543). Lo usa el runtime.
#   Debe incluir pgbouncer=true (deshabilita prepared statements persistentes).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: pooler de SESIÓN (puerto 5432). Lo usa Prisma para migraciones e
#   introspección (requiere conexión directa/de sesión, sin pgbouncer).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────────────────────────────────
# Supabase Realtime (cupos en vivo) — opcional
# ──────────────────────────────────────────────────────────────────────────
# Settings → API. Si faltan, la app funciona igual pero sin tiempo real.
# Requiere además: habilitar Realtime en la tabla `slots` y una policy RLS de
# SELECT para anon/authenticated (ver README).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# ──────────────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ──────────────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Generá uno con: openssl rand -base64 32
AUTH_SECRET="reemplazá-esto-por-un-secreto-largo-y-aleatorio"
# En producción configurá la URL pública del sitio.
# AUTH_URL="https://tu-dominio.com"
# Confiar en el host detrás del proxy (necesario en algunos hostings).
AUTH_TRUST_HOST="true"

# ──────────────────────────────────────────────────────────────────────────
# Reglas de negocio
# ──────────────────────────────────────────────────────────────────────────
# Zona horaria del estudio (IANA). Las franjas se interpretan en esta TZ.
NEXT_PUBLIC_TIMEZONE="America/Argentina/Buenos_Aires"
# Antelación mínima (en horas) con la que un paciente puede cancelar un turno.
CANCELLATION_MIN_HOURS="24"

# Defaults del modelo de cupos (opcionales; ver src/lib/booking-config.ts).
SLOT_CAPACITY_DEFAULT="20"
DAY_START="08:00"
DAY_END="21:00"
BLOCK_MINUTES="60"
LOW_SLOTS_THRESHOLD="3"
GENERATION_DAYS="30"

# ──────────────────────────────────────────────────────────────────────────
# Datos del seed (credenciales de prueba)
# ──────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@kinesio.local"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_PATIENT_EMAIL="paciente@kinesio.local"
SEED_PATIENT_PASSWORD="Paciente123!"
