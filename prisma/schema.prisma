generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Usuario del sistema. Puede ser ADMIN (kinesiólogo/recepción) o PATIENT.
model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("PATIENT")
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[] @relation("PatientAppointments")
  professional Professional?

  @@index([role])
}

/// Profesional (kinesiólogo) con agenda propia. Puede vincularse a un User ADMIN.
model Professional {
  id             String         @id @default(cuid())
  name           String
  specialty      String?
  bio            String?
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String?        @unique
  appointments   Appointment[]
  availabilities Availability[]
  user           User?          @relation(fields: [userId], references: [id])

  @@index([active])
}

/// Servicio ofrecido (define la duración del turno). Ej: "Sesión RPG 45 min".
model Service {
  id              String        @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]

  @@index([active])
}

/// Franja horaria laboral semanal de un profesional.
/// startTime/endTime se guardan como "HH:mm" (hora local de la consultoría).
model Availability {
  id             String       @id @default(cuid())
  dayOfWeek      Int
  startTime      String
  endTime        String
  professionalId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek, startTime, endTime])
  @@index([professionalId, dayOfWeek])
}

/// Turno reservado. startsAt/endsAt se guardan en UTC (DateTime).
model Appointment {
  id             String       @id @default(cuid())
  startsAt       DateTime
  endsAt         DateTime
  status         String       @default("PENDING")
  notes          String?
  patientId      String
  professionalId String
  serviceId      String
  cancelledAt    DateTime?
  cancelledBy    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  patient        User         @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id])

  @@index([professionalId, startsAt])
  @@index([patientId, startsAt])
  @@index([status])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bookings {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slot_id    String   @db.Uuid
  user_id    String
  status     String   @default("CONFIRMED")
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  slots      slots    @relation(fields: [slot_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([slot_id], map: "idx_bookings_slot")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model professionals {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  specialty      String?
  active         Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  slot_templates slot_templates[]
  slots          slots[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model slot_templates {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professional_id String?        @db.Uuid
  day_of_week     Int
  start_time      DateTime       @db.Time(6)
  end_time        DateTime       @db.Time(6)
  capacity        Int
  active          Boolean        @default(true)
  professionals   professionals? @relation(fields: [professional_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model slots {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professional_id String?        @db.Uuid
  date            DateTime       @db.Date
  start_time      DateTime       @db.Time(6)
  end_time        DateTime       @db.Time(6)
  capacity        Int
  booked_count    Int            @default(0)
  is_blocked      Boolean        @default(false)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  bookings        bookings[]
  professionals   professionals? @relation(fields: [professional_id], references: [id], onUpdate: NoAction)

  @@unique([professional_id, date, start_time])
  @@index([date], map: "idx_slots_date")
}
