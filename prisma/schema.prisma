// Prisma schema — Sistema de turnos por CUPOS (Supabase / PostgreSQL).
//
// - DATABASE_URL: pooler de transacción (6543, pgbouncer=true) → runtime.
// - DIRECT_URL: pooler de sesión (5432) → migraciones / db push / introspección.
//
// La reserva/cancelación NO se modelan acá: se hacen con las funciones atómicas
// book_slot / cancel_booking vía $queryRaw (ver src/server/services/booking.service.ts).
// Las tablas de cupos tienen RLS y check constraints en la base; Prisma las
// respeta aunque no las represente en el client. El runtime conecta como rol
// `postgres` (bypassea RLS); para el Realtime del navegador se agrega una
// policy de lectura (Fase 4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Catálogo de servicios del estudio (RPG, GYM, RECOVERY, etc.).
/// Las reglas de disponibilidad se almacenan en `schedule` (JSONB) para
/// que los dueños puedan editarlas sin tocar código.
model Service {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6366f1")
  capacity  Int      @default(1)
  schedule  Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  templates             SlotTemplate[]
  slots                 Slot[]
  bookings              Booking[]
  professionalServices  ProfessionalService[]

  @@map("services")
}

/// Usuario del sistema (autenticación). ADMIN o PATIENT.
/// Las reservas referencian este id (bookings.user_id = User.id, text),
/// sin clave foránea a nivel de base.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("PATIENT") // "ADMIN" | "PATIENT"
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ── Cobertura médica ────────────────────────────────────────────────────
  tipoCoberturaString   String?  @map("tipo_cobertura") @db.VarChar
  obraSocialNombre      String?  @map("obra_social_nombre")
  requiereCopago        Boolean  @default(false) @map("requiere_copago")
  montoCopago           Int?     @map("monto_copago")

  // ── Tratamiento ─────────────────────────────────────────────────────────
  sesionesTotales       Int      @default(0) @map("sesiones_totales")
  numeroSesionActual    Int      @default(0) @map("numero_sesion_actual")
  esPrimeraVez          Boolean  @default(true) @map("es_primera_vez")
  tratamientoInicio     DateTime? @map("tratamiento_inicio") @db.Timestamptz(6)
  tratamientoFin        DateTime? @map("tratamiento_fin") @db.Timestamptz(6)

  // ── Baja lógica + auditoría ─────────────────────────────────────────────
  archivedAt            DateTime? @map("archived_at") @db.Timestamptz(6)
  archivedBy            String?   @map("archived_by")
  updatedBy             String?   @map("updated_by")

  // ── Alta por el profesional + onboarding ────────────────────────────────
  mustChangePassword    Boolean   @default(false) @map("must_change_password")
  createdBy             String?   @map("created_by")

  @@index([role])
  @@index([archivedAt])
}

/// Profesional del estudio.
model Professional {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  specialty String?
  active    Boolean        @default(true)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  templates SlotTemplate[]
  slots     Slot[]

  services  ProfessionalService[]

  @@map("professionals")
}

/// Relación N:M entre profesionales y servicios habilitados.
model ProfessionalService {
  professionalId String       @map("professional_id") @db.Uuid
  serviceId      String       @map("service_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@map("professional_services")
}

/// Plantilla semanal: día de la semana + rango horario + capacidad.
/// A partir de las plantillas activas se materializan las franjas (slots).
model SlotTemplate {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String?       @map("professional_id") @db.Uuid
  serviceId      String?       @map("service_id") @db.Uuid
  dayOfWeek      Int           @map("day_of_week")
  startTime      DateTime      @map("start_time") @db.Time(6)
  endTime        DateTime      @map("end_time") @db.Time(6)
  capacity       Int
  active         Boolean       @default(true)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service        Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@map("slot_templates")
}

/// Franja concreta de un día, con capacidad y cupos ocupados (booked_count).
model Slot {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String?       @map("professional_id") @db.Uuid
  serviceId      String?       @map("service_id") @db.Uuid
  date           DateTime      @db.Date
  startTime      DateTime      @map("start_time") @db.Time(6)
  endTime        DateTime      @map("end_time") @db.Time(6)
  capacity       Int
  bookedCount    Int           @default(0) @map("booked_count")
  isBlocked      Boolean       @default(false) @map("is_blocked")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  professional   Professional? @relation(fields: [professionalId], references: [id], onUpdate: NoAction)
  service        Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  bookings       Booking[]

  @@unique([professionalId, date, startTime])
  @@index([date], map: "idx_slots_date")
  @@index([serviceId], map: "idx_slots_service")
  @@map("slots")
}

/// Reserva de un cupo. user_id = User.id (text), sin FK a nivel de base.
model Booking {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slotId    String   @map("slot_id") @db.Uuid
  userId    String   @map("user_id")
  serviceId String?  @map("service_id") @db.Uuid
  status    String   @default("CONFIRMED") // "CONFIRMED" | "CANCELLED"
  notes     String?
  recurrenceId String? @map("recurrence_id") @db.Uuid
  isOverride Boolean  @default(false) @map("is_override")
  overrideBy String?  @map("override_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  slot      Slot        @relation(fields: [slotId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service   Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  attendance Attendance?

  @@index([slotId], map: "idx_bookings_slot")
  @@index([serviceId], map: "idx_bookings_service")
  @@index([recurrenceId], map: "idx_bookings_recurrence")
  @@map("bookings")
}

/// Pago de un paciente: copago (por turno/mes) o cobro extra puntual.
/// user_id = User.id del paciente; recorded_by_id = User.id del profesional.
/// Sin FK a nivel de base (consistente con bookings/attendances).
model Payment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id")
  type         String    // "COPAGO" | "EXTRA"
  amount       Int       // total en $ (pesos)
  quantity     Int       @default(1) // copagos que cubre (COPAGO); 1 para EXTRA
  periodMonth  Int       @map("period_month") // 1..12
  periodYear   Int       @map("period_year")
  concept      String?
  paidAt       DateTime  @default(now()) @map("paid_at") @db.Timestamptz(6)
  recordedById String    @map("recorded_by_id")
  recordedAt   DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  voidedAt     DateTime? @map("voided_at") @db.Timestamptz(6)
  voidedById   String?   @map("voided_by_id")
  voidReason   String?   @map("void_reason")

  @@index([userId])
  @@index([periodYear, periodMonth])
  @@index([type])
  @@map("payments")
}

/// Configuración de facturación (una sola fila, id = 1). Monto del copago.
model BillingSetting {
  id           Int      @id @default(1)
  copagoAmount Int      @default(4000) @map("copago_amount")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("billing_settings")
}

/// Asistencia a una reserva. Un registro por reserva.
model Attendance {
  bookingId String   @id @map("booking_id") @db.Uuid
  status    String   @default("PENDING") // "PRESENT" | "ABSENT" | "LATE" | "PENDING"
  markedBy  String   @map("marked_by")
  markedAt  DateTime @default(now()) @map("marked_at") @db.Timestamptz(6)

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("attendances")
}
